# =============================================================================
# Container environment template.
#
#   Local dev:  cp .env.docker.example .env.docker   (then fill in the blanks)
#   Dokploy:    paste these keys into the service's Environment settings
#               (do NOT commit real values — .env.docker is gitignored)
# =============================================================================

# ---- Application ----
APP_NAME="Track Progress TIM"
APP_ENV=production
APP_KEY=                      # REQUIRED. Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-domain.example

# ---- Database (point these at your Dokploy MariaDB service in prod) ----
DB_CONNECTION=mysql
DB_HOST=db                    # local: "db" (compose service). prod: Dokploy DB host
DB_PORT=3306
DB_DATABASE=trackprogresstim
DB_USERNAME=laravel
DB_PASSWORD=changeme
# DB_ROOT_PASSWORD is only used by the bundled local `db` service in compose.
DB_ROOT_PASSWORD=changeme-root

# ---- First-boot seed dump location inside the container ----
# The entrypoint imports this ONLY when the database has no `migrations` table.
SEED_FILE=/var/www/seed/init.sql

# ---- Cache / queue / session ----
CACHE_DRIVER=file
QUEUE_CONNECTION=database
QUEUE_RETRY_AFTER=3600
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ---- Logging ----
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ---- Mail (local: mailpit) ----
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"
