# ---- Dependencies & build artifacts (NEVER commit these) ----
/vendor
/node_modules
/public/build
/public/hot
/public/storage

# ---- Laravel storage & caches ----
/storage/*.key
/storage/pail
/.phpunit.cache
/.phpunit.result.cache
.phpunit.result.cache

# ---- Environment & secrets ----
.env
.env.*
!.env.example
!.env.docker.example
.env.backup
.env.production
auth.json
Homestead.json
Homestead.yaml

# ---- Database dumps ----
# Stray/ad-hoc dumps anywhere (e.g. the raw prod export) stay OUT of git:
*.sql
# ...EXCEPT the intentionally-committed bundled seed (private repo):
!database/seed/init.sql
!database/seed/init.sql.gz

# ---- Logs & misc ----
npm-debug.log
yarn-error.log
*.log

# ---- Editor / OS ----
/.fleet
/.idea
/.vscode
/.nova
/.zed
.DS_Store
Thumbs.db
