* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

# Binary assets — never apply EOL/text normalization (would corrupt them)
*.gz              binary

# Container scripts must always be LF (they run inside Linux)
*.sh              text eol=lf
docker/entrypoint.sh text eol=lf
Dockerfile        text eol=lf
docker-compose*.yml text eol=lf

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore
