# Version control
.git
.gitignore
.gitattributes

# Dependencies & build output (rebuilt inside the image)
vendor
node_modules
public/build
public/hot
public/storage

# Secrets & local env (Dokploy injects env vars at runtime)
.env
.env.*
!.env.docker.example

# Raw/ad-hoc SQL dumps stay out of the image (the big root export, etc.)...
*.sql
# ...but the bundled, gzipped seed IS shipped so the container can self-seed:
!database/seed/init.sql.gz

# Runtime-generated storage (kept empty in the image)
storage/app/public/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
bootstrap/cache/*.php

# Dev-only tooling & docs
tests
.github
.editorconfig
.phpunit.cache
.phpunit.result.cache
phpunit.xml
docker-compose*.yml
docs
README.md
*.md
webpack.mix.js
test_vhts_v3_data.txt
